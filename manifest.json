{
  "manifest_version": 3,
  "name": "ARV Security Sentinel",
  "version": "0.1.0",
  "description": "Auditoria defensiva de seguridad web con hallazgos y recomendaciones accionables.",
  "action": {
    "default_title": "ARV Security Sentinel",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "assets/background.js"
  },
  "permissions": ["activeTab", "tabs", "storage", "cookies", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
